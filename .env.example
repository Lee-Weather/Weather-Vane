# ============================================================
# AI 论文每日推送系统 — 环境变量配置示例
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# .env 已加入 .gitignore，不会提交到版本库
# ============================================================

# ── DeepSeek API ─────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ── Semantic Scholar API（可选，有 key 则限速更宽松）──────────
SEMANTIC_SCHOLAR_API_KEY=

# ── Telegram Bot 推送（可选）────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email SMTP 推送（可选）──────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=
