# ============================================================
# .gitignore — AI 论文每日推送系统
# ============================================================

# ── 环境变量（绝对不入库）────────────────────────────────────
.env

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── 虚拟环境 ────────────────────────────────────────────────
.venv/
venv/
env/
# conda 环境目录（如放在项目内）
conda-env/

# ── 每日数据产物（可选：按需保留或忽略）────────────────────
# 取消注释以忽略中间 JSON 文件（建议保留用于调试）
# data/*.json

# 忽略 SQLite 数据库（体积可能较大，建议单独备份）
data/papers.db

# ── 测试与覆盖率 ────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── IDE / 编辑器 ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 日志文件 ────────────────────────────────────────────────
*.log
logs/
